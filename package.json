{
  "name": "webapp",
  "version": "1.0.0",
  "description": "Scroll-driven 3D camera animation",
  "type": "module",
  "main": "src/translink/main.ts",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "tsc && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview --port 3002",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist node_modules dist-server",
    "clean:cache": "rimraf node_modules/.vite",
    "server:dev": "tsx server/index.ts",
    "server:start": "tsx server/index.ts",
    "voice:readiness": "tsx scripts/voice-readiness-check.ts"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "animejs": "^4.4.1",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "flubber": "^0.4.2",
    "gsap": "^3.14.2",
    "lenis": "1.3.16",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "postcss": "^8.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.17",
    "three": "0.175.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/animejs": "^3.1.13",
    "@types/express": "^5.0.6",
    "@types/flubber": "^0.4.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.175.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "prettier": "3.3.3",
    "rimraf": "^5.0.5",
    "tsx": "^4.22.1",
    "typescript": "5.9.3",
    "vite": "^6.2.5"
  },
  "keywords": [
    "3d",
    "webgl",
    "three.js",
    "gsap",
    "scroll-animation",
    "translink"
  ],
  "author": "OFF+BRAND",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "picomatch": "^2.3.2",
    "esbuild": "^0.25.0",
    "rollup": "^4.59.0"
  }
}
