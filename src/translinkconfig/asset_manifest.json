{
  "version": "1.0.0",

  "models": {
    "sensor": {
      "name": "Sensor Assembly",
      "path": "./models/sensor_assembly_meshopt.glb",
      "format": "glb",
      "compression": "meshopt",
      "envOverride": "VITE_SENSOR_PATH"
    },
    "truck": {
      "name": "Truck Assembly",
      "path": "./models/truck_assembly_meshopt.glb",
      "format": "glb",
      "compression": "meshopt",
      "envOverride": "VITE_TRUCK_PATH"
    }
  },

  "textures": {
    "studioHdr": {
      "name": "Studio Environment HDR",
      "path": "./textures/hdr/studio_small_09_1k.hdr",
      "format": "hdr",
      "resolution": "1k",
      "envOverride": "VITE_HDR_PATH"
    }
  },

  "audio": {
    "ambient-relaxation": {
      "name": "Immersive Relaxation (Ambient)",
      "path": "./assets/audio/immersive-relaxation.mp3",
      "format": "mp3",
      "sizeBytes": 615235
    },
    "swoosh-orbit-harness": {
      "name": "Swoosh Orbit 3 (Harness 9%)",
      "path": "./assets/audio/swoosh-orbit-3.mp3",
      "format": "mp3",
      "sizeBytes": 36096
    },
    "swoosh-orbit-fuel-tank": {
      "name": "Swoosh Orbit 2 (Fuel Tank 36%)",
      "path": "./assets/audio/swoosh-orbit-2.mp3",
      "format": "mp3",
      "sizeBytes": 66037
    },
    "swoosh-orbit-exit": {
      "name": "Swoosh Orbit (Exit 85%)",
      "path": "./assets/audio/swoosh-orbit.mp3",
      "format": "mp3",
      "sizeBytes": 34560
    },
    "truck-engine-start": {
      "name": "Truck Engine Start",
      "path": "./assets/audio/Truck-Engine-Start.mp3",
      "format": "mp3",
      "sizeBytes": 24000
    },
    "truck-engine-run": {
      "name": "Truck Engine Run (Loop)",
      "path": "./assets/audio/Truck-Engine-Run.mp3",
      "format": "mp3",
      "sizeBytes": 912822
    },
    "truck-air-brake": {
      "name": "Truck Air Brake (Foot Pedal)",
      "path": "./assets/audio/Truck-Recycling-Air_Brake-Foot_Pedal.mp3",
      "format": "mp3",
      "sizeBytes": 19226
    }
  },

  "camera": {
    "defaults": {
      "fov": 35,
      "near": 0.1,
      "far": 1000,
      "initialPosition": [5, 1.5, 5]
    }
  },

  "renderer": {
    "antialias": true,
    "powerPreference": "high-performance",
    "alpha": false,
    "enableShadows": true,
    "envOverrides": {
      "maxPixelRatio": "VITE_MAX_PIXEL_RATIO",
      "enableShadows": "VITE_ENABLE_SHADOWS",
      "debug": "VITE_DEBUG",
      "cameraDebug": "VITE_CAMERA_DEBUG"
    }
  }
}
